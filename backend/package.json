{
  "name": "workforce-task-management-backend",
  "version": "0.1.0",
  "description": "Backend API for the Cloud-Based Workforce Task Management System.",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed:demo-users": "node scripts/seed-demo-users.js",
    "seed:demo-group": "node scripts/seed-demo-group.js",
    "audit:local": "node scripts/deep-audit.js",
    "smoke": "node scripts/smoke-test.js",
    "smoke:local": "SMOKE_TEST_BASE_URL=http://localhost:4000 SMOKE_TEST_EXPECT_MANAGER_ACCESS=true node scripts/smoke-test.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "pg": "^8.16.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4",
    "vitest": "^4.0.0"
  }
}
