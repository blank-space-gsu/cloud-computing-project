# Application
NODE_ENV=development
PORT=4000
APP_NAME=workforce-task-management-backend
API_PREFIX=/api/v1

# Frontend integration
FRONTEND_APP_ORIGIN=http://localhost:5500
SUPABASE_AUTH_EMAIL_REDIRECT_TO=http://localhost:5500
# Production example:
# FRONTEND_APP_ORIGIN=https://tasktrail.site
# SUPABASE_AUTH_EMAIL_REDIRECT_TO=https://tasktrail.site
# Supabase Auth SMTP stays in the Supabase dashboard / Management API.
# For TaskTrail production, configure custom SMTP there with Resend
# instead of storing SMTP credentials in this backend env file.

# Supabase
SUPABASE_PROJECT_REF=dfllpxijgfcoazwstegl
SUPABASE_URL=https://dfllpxijgfcoazwstegl.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Database
DATABASE_URL=postgresql://postgres.dfllpxijgfcoazwstegl:[YOUR-DB-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres?sslmode=no-verify
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Demo data
DEMO_USER_PASSWORD=your-demo-user-password

# Optional smoke testing
SMOKE_TEST_BASE_URL=http://localhost:4000
SMOKE_TEST_EMAIL=manager.demo@cloudcomputing.local
SMOKE_TEST_PASSWORD=your-demo-user-password
SMOKE_TEST_EXPECT_MANAGER_ACCESS=true
